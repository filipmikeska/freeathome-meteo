# === ABB free@home API ===
# Režim: "cloud" pro produkci, "local" pro vývoj na lokální síti
ABB_API_MODE=cloud

# Identifikace zařízení
ABB_SYSAP_UUID=8cf4903d-885c-43ef-9fea-bba1167b5928
ABB_DEVICE_ID=7EB10000329B

# Cloud API (https://developer.eu.mybuildings.abb.com/fah_cloud)
ABB_CLOUD_TOKEN=
ABB_CLOUD_SUBSCRIPTION_KEY=

# Local API (https://developer.eu.mybuildings.abb.com/fah_local)
ABB_LOCAL_HOST=192.168.68.55
ABB_LOCAL_USER=installer
ABB_LOCAL_PASSWORD=

# === Turso databáze ===
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=

# === Zabezpečení ===
# Tajný klíč pro /api/collect endpoint (vygenerujte náhodný řetězec)
COLLECT_API_KEY=

# === Aplikace ===
# Polling interval na frontendu (ms)
NEXT_PUBLIC_POLL_INTERVAL=60000
