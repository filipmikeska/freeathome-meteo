# ABB free@home SysAP - lokální přístup
# POZOR: IP SysAPu ověř přes ping / router — mění se. Aktuálně 192.168.68.56
ABB_DEVICE_ID=7EB10000329B
ABB_LOCAL_HOST=192.168.68.56
ABB_LOCAL_USER=installer
ABB_LOCAL_PASSWORD=your_password_here

# Turso databáze
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your_auth_token_here

# Pro Raspberry Pi — cron musí mít NODE_TLS_REJECT_UNAUTHORIZED=0
# kvůli self-signed certifikátu SysAPu. Viz docs/rpi-setup-runbook.md
